generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                 String   @id @default(cuid())

  fullName           String
  email              String
  phone              String

  company            String?
  service            String

  budget             String?
  contactMethod      String?
  timeline           String?

  projectDescription String?

  status             String   @default("NEW")

  notes              String?

  converted          Boolean  @default(false)

  projectId          String?

  createdAt          DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())

  projectName String
  clientName  String

  email       String
  phone       String

  company     String?
  service     String

  description String?

  status      String   @default("PLANNING")

  progress    Int      @default(0)

  createdAt   DateTime @default(now())
}

model Admin {
  id        String   @id @default(cuid())

  name      String
  email     String   @unique

  password  String

  createdAt DateTime @default(now())
}