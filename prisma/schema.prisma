generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                 String   @id @default(cuid())

  fullName           String
  email              String
  phone              String

  company            String?
  service            String

  budget             String?
  contactMethod      String?
  timeline           String?

  projectDescription String?

  status String @default("NEW_LEAD")

  notes              String?

  converted          Boolean  @default(false)

  projectId          String?

  createdAt          DateTime @default(now())
  sentEmails         SentEmail[]

  @@index([projectId])
}

model Project {
  id          String   @id @default(cuid())

  projectName String

  clientName  String

  email       String

  phone       String

  company     String?

  service     String

  status      String   @default("PLANNING")

  description String?

  progress    Int      @default(0)

  createdAt   DateTime @default(now())

  clientId    String?

  client      Client?  @relation(fields: [clientId], references: [id])
  invoices    Invoice[]
  sentEmails  SentEmail[]

  @@index([clientId])
}

model Client {
  id              String    @id @default(cuid())

  company         String
  contactPerson   String

  email           String
  phone           String

  website         String?
  address         String?
  industry        String?

  notes           String?

  createdAt       DateTime  @default(now())

  projects        Project[]
  clientUsers     ClientUser[]
  documents       Document[]
  invoices        Invoice[]
  sentEmails      SentEmail[]
}

model ClientUser {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fullName     String
  email        String   @unique
  passwordHash String
  role         String   @default("CLIENT")
  active       Boolean  @default(true)
  lastLogin    DateTime?
  resetToken   String?
  resetTokenExp DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sentEmails   SentEmail[]

  @@index([clientId])
}

model Document {
  id        String   @id @default(cuid())
  title     String
  fileUrl   String
  fileSize  String
  category  String   // e.g. "PROPOSAL", "AGREEMENT", "INVOICE", "REQUIREMENTS", "SRS", "DEPLOYMENT"
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model Admin {
  id        String   @id @default(cuid())

  name      String
  email     String   @unique

  password  String

  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // e.g. "NEW_LEAD", "PROJECT_CREATED", "CMS_UPDATED", "LOGIN_ACTIVITY"
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model WebsiteSettings {
  id                   String   @id @default("default")
  companyName          String
  tagline              String
  email                String
  phone                String
  whatsapp             String
  officeAddress        String
  googleMapsLink       String   @db.Text
  workingHours         String
  logoUrl              String
  faviconUrl           String
  linkedin             String?
  instagram            String?
  facebook             String?
  twitter              String?
  youtube              String?
  defaultSeoTitle      String
  defaultSeoDescription String
  
  ceoName              String   @default("M. Prasanna Kumar")
  ceoDesignation       String   @default("Founder & Managing Director")
  ceoSignatureUrl      String   @default("")
}

model Service {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String   @db.Text
  longDescription  String   @db.Text
  icon             String
  displayOrder     Int      @default(0)
  active           Boolean  @default(true)
  features         String[]
  technologies     String[]
}

model Industry {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String   @db.Text
  icon         String
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  solutions    String[]
}

model FAQ {
  id           String   @id @default(cuid())
  question     String   @db.Text
  answer       String   @db.Text
  category     String
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
}

model Technology {
  id           String   @id @default(cuid())
  name         String
  logo         String?
  category     String
  displayOrder Int      @default(0)
}

model HomepageSection {
  id                 String   @id @default("default")
  heroTitleNormal    String
  heroTitleHighlight String
  heroSubtitle       String   @db.Text
  ctaText            String
  ctaLink            String
  whyChooseUs        Json
  devProcess         Json
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  invoiceDate   DateTime
  dueDate       DateTime
  
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  status        String        @default("DRAFT") // DRAFT, SENT, PAID, CANCELLED, OVERDUE
  
  subtotal      Float
  vatRate       Float         @default(5.0)     // VAT %
  vatAmount     Float
  discount      Float         @default(0.0)
  grandTotal    Float
  amountInWords String
  notes         String?       @db.Text
  
  authorizedBy  String        @default("Authorized By")
  founderName   String        @default("M. Prasanna Kumar")
  designation   String        @default("Founder & Managing Director")
  signatureUrl  String?
  
  paymentStatus String        @default("UNPAID") // UNPAID, PARTIALLY_PAID, PAID
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  items         InvoiceItem[]
  payments      Payment[]
  sentEmails    SentEmail[]

  @@index([clientId])
  @@index([projectId])
}

model InvoiceItem {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serialNumber Int
  description  String
  quantity     Float
  unitPrice    Float
  amount       Float

  @@index([invoiceId])
}

model Payment {
  id               String   @id @default(cuid())
  invoiceId        String
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount           Float
  paymentDate      DateTime @default(now())
  paymentMethod    String   // e.g. "STRIPE", "BANK_TRANSFER", "CASH"
  transactionId    String?
  paymentReference String?
  createdAt        DateTime @default(now())

  @@index([invoiceId])
}

model SentEmail {
  id           String      @id @default(cuid())
  recipient    String
  subject      String
  body         String      @db.Text
  type         String      // WELCOME, PORTAL_CREDENTIALS, INVOICE, PAYMENT_RECEIPT, PASSWORD_RESET, CONSULTATION_CONFIRMATION, ADMIN_NOTIFICATION, PROJECT_STATUS, GENERAL
  status       String      @default("PENDING") // PENDING, SENT, FAILED
  errorMessage String?     @db.Text
  createdBy    String      @default("SYSTEM")  // SYSTEM, ADMIN
  
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leadId       String?
  lead         Lead?       @relation(fields: [leadId], references: [id], onDelete: SetNull)
  invoiceId    String?
  invoice      Invoice?    @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  clientUserId String?
  clientUser   ClientUser? @relation(fields: [clientUserId], references: [id], onDelete: SetNull)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([clientId])
  @@index([leadId])
  @@index([invoiceId])
  @@index([projectId])
  @@index([clientUserId])
}